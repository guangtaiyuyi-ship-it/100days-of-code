# ==========================================
# データベースと環境固有データの除外 (必須)
# ==========================================
# Flaskが自動生成した instance フォルダとその中身（todo.dbなど）をすべて無視
instance/
*.db

# ==========================================
# Pythonの仮想環境とキャッシュの除外
# ==========================================
# ターミナルで見えていた (.venv) などの仮想環境フォルダを除外
.venv/
venv/
ENV/

# Pythonが実行時に自動生成するキャッシュフォルダを除外
__pycache__/
*.pyc

# ==========================================
# OS固有のゴミ箱ファイルの除外
# ==========================================
# WindowsやMacが自動生成するフォルダの見た目設定ファイルを除外
.DS_Store
Thumbs.db
